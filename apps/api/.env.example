# ─── Uygulama ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
LOG_LEVEL=debug

# Sunucunuzun dışa açık URL'i (ngrok veya Railway URL)
# Örn: https://abc123.ngrok-free.app
PUBLIC_URL=

# ─── Telegram ────────────────────────────────────────────────────────────────
# BotFather'dan alınır: /newbot komutu
TELEGRAM_BOT_TOKEN=

# Opsiyonel: Webhook güvenliği için rastgele bir string
# Örn: openssl rand -hex 16
TELEGRAM_SECRET_TOKEN=

# ─── WhatsApp (Onay geldikten sonra doldurulacak) ─────────────────────────────
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ─── AI ──────────────────────────────────────────────────────────────────────
# aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Redis ───────────────────────────────────────────────────────────────────
# Lokal geliştirme: redis://localhost:6379
# Upstash: rediss://...
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# openssl rand -hex 32
JWT_SECRET=

# ─── Veritabanı (Prisma - sonraki fazda) ──────────────────────────────────────
# DATABASE_URL=postgresql://...
# DIRECT_URL=postgresql://...
