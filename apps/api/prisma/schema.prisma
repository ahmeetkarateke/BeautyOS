generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-1.1.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Plan {
  basic
  pro
  business
  enterprise
}

enum UserRole {
  owner
  manager
  staff
}

enum CustomerSegment {
  vip
  regular
  sleeping
  at_risk
}

enum AppointmentStatus {
  pending
  confirmed
  in_progress
  completed
  cancelled
  no_show
}

enum BookingChannel {
  whatsapp
  telegram
  web
  manual
}

enum PaymentMethod {
  cash
  card
  mixed
  online
}

enum TransactionStatus {
  pending
  completed
  refunded
}

enum ResourceType {
  room
  chair
  device
}

enum NotificationChannel {
  whatsapp
  telegram
  sms
  push
  email
}

enum NotificationType {
  booking_confirm
  reminder_24h
  reminder_2h
  campaign
  waitlist
  cancellation
}

enum CommissionType {
  percentage
  fixed
}

enum LeaveType {
  day_off
  sick_leave
  vacation
  other
}

// ─── Tenant (Salon / İşletme) ─────────────────────────────────────────────────

model Tenant {
  id                 String    @id @default(uuid()) @db.Uuid
  name               String
  slug               String    @unique
  plan               Plan      @default(basic)
  whatsappNumber     String?
  whatsappApiToken   String?
  telegramBotToken   String?
  settings           Json      @default("{}")
  isActive           Boolean   @default(true)
  trialEndsAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  users              User[]
  staffProfiles               StaffProfile[]
  customers                   Customer[]
  services                    Service[]
  resources                   Resource[]
  appointments                Appointment[]
  transactions                Transaction[]
  expenses                    Expense[]
  inventory                   InventoryItem[]
  notificationLogs            NotificationLog[]
  staffServiceAssignments     StaffServiceAssignment[]
  staffLeaves                 StaffLeave[]

  @@map("tenants")
}

// ─── User (Kullanıcı Hesabı) ──────────────────────────────────────────────────

model User {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @db.Uuid
  email        String
  passwordHash String
  role         UserRole  @default(staff)
  fullName     String
  phone        String?
  avatarUrl    String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id])
  staffProfile StaffProfile?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

// ─── Staff Profile (Personel Profili) ────────────────────────────────────────

model StaffProfile {
  id                   String    @id @default(uuid()) @db.Uuid
  userId               String    @unique @db.Uuid
  tenantId             String    @db.Uuid
  title                String
  bio                  String?
  workingHours         Json      @default("{}")
  expertiseTags        String[]
  colorCode            Int?
  acceptsOnlineBooking Boolean   @default(true)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user               User                     @relation(fields: [userId], references: [id])
  tenant             Tenant                   @relation(fields: [tenantId], references: [id])
  appointments       Appointment[]
  serviceAssignments StaffServiceAssignment[]
  leaves             StaffLeave[]

  @@index([tenantId])
  @@map("staff_profiles")
}

// ─── Customer (Müşteri) ───────────────────────────────────────────────────────

model Customer {
  id               String          @id @default(uuid()) @db.Uuid
  tenantId         String          @db.Uuid
  fullName         String
  phone            String
  email            String?
  birthDate        DateTime?       @db.Date
  allergyNotes     String?
  preferenceNotes  String?
  totalVisits      Int             @default(0)
  lifetimeValue    Decimal         @default(0) @db.Decimal(10, 2)
  segment          CustomerSegment @default(regular)
  lastVisitAt      DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  appointments     Appointment[]
  notificationLogs NotificationLog[]

  @@unique([tenantId, phone])
  @@index([tenantId])
  @@map("customers")
}

// ─── Service (Hizmet) ─────────────────────────────────────────────────────────

model Service {
  id               String   @id @default(uuid()) @db.Uuid
  tenantId         String   @db.Uuid
  name             String
  category         String?
  durationMinutes  Int
  bufferMinutes    Int      @default(0)
  price            Decimal  @db.Decimal(10, 2)
  commissionRate   Decimal  @default(0) @db.Decimal(4, 4)
  requiresDeposit  Boolean  @default(false)
  depositAmount    Decimal? @db.Decimal(10, 2)
  isOnlineBookable Boolean  @default(true)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant           Tenant                   @relation(fields: [tenantId], references: [id])
  appointments     Appointment[]
  staffAssignments StaffServiceAssignment[]

  @@index([tenantId])
  @@map("services")
}

// ─── Resource (Oda / Koltuk / Cihaz) ─────────────────────────────────────────

model Resource {
  id       String       @id @default(uuid()) @db.Uuid
  tenantId String       @db.Uuid
  name     String
  type     ResourceType
  isActive Boolean      @default(true)

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  appointments Appointment[]

  @@index([tenantId])
  @@map("resources")
}

// ─── Appointment (Randevu) ────────────────────────────────────────────────────

model Appointment {
  id                 String            @id @default(uuid()) @db.Uuid
  tenantId           String            @db.Uuid
  customerId         String            @db.Uuid
  staffId            String            @db.Uuid
  serviceId          String            @db.Uuid
  resourceId         String?           @db.Uuid
  referenceCode      String            @unique
  status             AppointmentStatus @default(pending)
  bookingChannel     BookingChannel    @default(manual)
  startAt            DateTime
  endAt              DateTime
  priceCharged       Decimal           @db.Decimal(10, 2)
  notes              String?
  cancellationReason String?
  cancelledById      String?           @db.Uuid
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  tenant       Tenant            @relation(fields: [tenantId], references: [id])
  customer     Customer          @relation(fields: [customerId], references: [id])
  staff        StaffProfile      @relation(fields: [staffId], references: [id])
  service      Service           @relation(fields: [serviceId], references: [id])
  resource     Resource?         @relation(fields: [resourceId], references: [id])
  transactions Transaction[]
  notificationLogs NotificationLog[]

  @@index([tenantId])
  @@index([tenantId, startAt])
  @@index([customerId])
  @@index([staffId, startAt])
  @@map("appointments")
}

// ─── Transaction (Ödeme / Prim) ───────────────────────────────────────────────

model Transaction {
  id               String            @id @default(uuid()) @db.Uuid
  tenantId         String            @db.Uuid
  appointmentId    String?           @db.Uuid
  staffId          String?           @db.Uuid
  grossAmount      Decimal           @db.Decimal(10, 2)
  commissionAmount Decimal           @db.Decimal(10, 2)
  commissionRate   Decimal           @db.Decimal(4, 4)
  paymentMethod    PaymentMethod     @default(cash)
  cashAmount       Decimal           @default(0) @db.Decimal(10, 2)
  cardAmount       Decimal           @default(0) @db.Decimal(10, 2)
  depositDeducted  Decimal           @default(0) @db.Decimal(10, 2)
  status           TransactionStatus @default(pending)
  notes            String?
  completedAt      DateTime?
  createdAt        DateTime          @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([appointmentId])
  @@map("transactions")
}

// ─── Expense (Gider) ──────────────────────────────────────────────────────────

model Expense {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @db.Uuid
  title          String
  category       String
  amount         Decimal  @db.Decimal(10, 2)
  expenseDate    DateTime @db.Date
  receiptUrl     String?
  isRecurring    Boolean  @default(false)
  recurrenceRule String?
  createdAt      DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("expenses")
}

// ─── Inventory (Stok) ─────────────────────────────────────────────────────────

model InventoryItem {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @db.Uuid
  name              String
  sku               String?
  quantity          Int      @default(0)
  lowStockThreshold Int      @default(5)
  unitCost          Decimal  @db.Decimal(10, 2)
  sellingPrice      Decimal? @db.Decimal(10, 2)
  unit              String   @default("adet")
  updatedAt         DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("inventory")
}

// ─── Notification Log ─────────────────────────────────────────────────────────

model NotificationLog {
  id            String              @id @default(uuid()) @db.Uuid
  tenantId      String              @db.Uuid
  customerId    String?             @db.Uuid
  appointmentId String?             @db.Uuid
  channel       NotificationChannel
  type          NotificationType
  status        String              @default("sent")
  createdAt     DateTime            @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  customer    Customer?    @relation(fields: [customerId], references: [id])
  appointment Appointment? @relation(fields: [appointmentId], references: [id])

  @@index([tenantId])
  @@index([appointmentId])
  @@map("notification_logs")
}

// ─── Staff Service Assignment (Personel-Hizmet Atama) ────────────────────────

model StaffServiceAssignment {
  id              String         @id @default(uuid()) @db.Uuid
  staffId         String         @db.Uuid
  serviceId       String         @db.Uuid
  tenantId        String         @db.Uuid
  commissionType  CommissionType @default(percentage)
  commissionValue Decimal        @default(0) @db.Decimal(10, 2)
  priceOverride   Decimal?       @db.Decimal(10, 2)
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())

  staff   StaffProfile @relation(fields: [staffId], references: [id])
  service Service      @relation(fields: [serviceId], references: [id])
  tenant  Tenant       @relation(fields: [tenantId], references: [id])

  @@unique([staffId, serviceId])
  @@index([staffId])
  @@index([serviceId])
  @@index([tenantId])
  @@map("staff_service_assignments")
}

// ─── Staff Leave (Personel İzin) ─────────────────────────────────────────────

model StaffLeave {
  id        String    @id @default(uuid()) @db.Uuid
  staffId   String    @db.Uuid
  tenantId  String    @db.Uuid
  leaveDate DateTime  @db.Date
  leaveType LeaveType @default(day_off)
  note      String?
  createdAt DateTime  @default(now())

  staff  StaffProfile @relation(fields: [staffId], references: [id])
  tenant Tenant       @relation(fields: [tenantId], references: [id])

  @@index([staffId])
  @@index([tenantId, leaveDate])
  @@map("staff_leaves")
}
